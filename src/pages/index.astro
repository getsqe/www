---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import CompareTable from '../components/CompareTable.astro';
import matrix from '../data/iceberg-matrix.json';
import perf from '../data/performance.json';
import landing from '../data/landing.json';

const DOCS = 'https://docs.getsqe.com';
const GITHUB = 'https://github.com/schubergphilis/sqe';

// Authored copy synced from docs/site/web/landing.json (single content home).
const { features, compareHead, compareRows, bench } = landing;
---

<BaseLayout
  title="SQE — Sovereign Query Engine | Iceberg-first SQL that scales"
  darkHeader
>
  <Hero />

  <!-- WHY -->
  <section class="section" id="why">
    <div class="container">
      <SectionHeading eyebrow="Why SQE" title="The lakehouse engine you actually own." center />
      <div class="why-grid">
        <div class="card why-card">
          <div class="why-stat"><span class="stat-num">{matrix.score.percent}%</span></div>
          <h3>Top-five on the public Iceberg matrix</h3>
          <p>{matrix.score.raw}/{matrix.score.max} cells. The only non-Spark engine in the top five —
            scored against the public <a href="https://icebergmatrix.org" rel="noopener">rubric</a>, not a vendor spec sheet.</p>
          <a href="/compare/iceberg" class="why-link">See the matrix →</a>
        </div>
        <div class="card why-card">
          <div class="why-stat"><span class="stat-num">6/7</span></div>
          <h3>Benchmark suites won vs Trino 465</h3>
          <p>222 of 222 queries pass at SF1. Up to 18.5× faster on TPC-E. Reproducible with one script.</p>
          <a href="#proof" class="why-link">See the receipts →</a>
        </div>
        <div class="card why-card">
          <div class="why-stat"><span class="stat-num">0</span></div>
          <h3>Service accounts. Zero shared roots.</h3>
          <p>Every query runs as the authenticated user. The bearer token flows through to the catalog
            and storage. Policy is enforced before the optimizer runs.</p>
          <a href="/compare/trino" class="why-link">vs Trino →</a>
        </div>
        <div class="card why-card">
          <div class="why-stat"><span class="stat-num">1</span></div>
          <h3>Binary, laptop to cluster</h3>
          <p>A DuckDB-class embedded engine and a distributed coordinator share one SQL surface.
            Cross-catalog joins, runtime <code>ATTACH</code>, persistent local warehouse.</p>
          <a href="/compare/duckdb" class="why-link">vs DuckDB →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT -->
  <section class="section section--tight what" id="what">
    <div class="container">
      <SectionHeading eyebrow="What it is" title="Everything in one engine." />
      <FeatureGrid items={features} columns={4} />
    </div>
  </section>

  <!-- HOW -->
  <section class="section how" id="how">
    <div class="container">
      <SectionHeading eyebrow="How to run it" title="Two commands to a SQL prompt." />
      <div class="how-grid">
        <div>
          <h3 class="section-marker">Embedded — one binary, no cluster</h3>
          <pre class="code"><code>{`cargo install --path crates/sqe-cli
sqe-cli --embedded          # persistent warehouse at ~/.sqe/warehouse/

sqe> SELECT * FROM '/data/sales.parquet' LIMIT 5;
sqe> SELECT * FROM read_csv('s3://bucket/orders.tsv.gz');
sqe> ATTACH 'http://catalog.example.com/api/catalog' AS partner_cat
       (TYPE iceberg_rest, WAREHOUSE 'analytics');
sqe> SELECT * FROM partner_cat.sales.orders LIMIT 10;`}</code></pre>
        </div>
        <div>
          <h3 class="section-marker">Cluster — Polaris + S3 + SQE locally</h3>
          <pre class="code"><code>{`docker compose -f docker-compose.test.yml up -d
./scripts/bootstrap-test.sh
cargo run --release --bin sqe-coordinator -- tests/sqe-test.toml

# Connect with the CLI over Arrow Flight SQL
cargo run --bin sqe-cli -- --host localhost --port 50051 \\
  --username root --protocol flight

sqe> SHOW CATALOGS;
sqe> SELECT * FROM test_warehouse.default.my_table LIMIT 10;`}</code></pre>
        </div>
      </div>
      <p class="how-foot">Full quickstart covering all seven catalog backends → <a href={DOCS}>docs.getsqe.com</a></p>
    </div>
  </section>

  <!-- PROOF -->
  <section class="section proof" id="proof">
    <div class="container">
      <SectionHeading eyebrow="Receipts" title="How SQE differs." />
      <CompareTable head={compareHead} rows={compareRows} />

      <h3 class="proof-sub section-marker">Performance — SF1, vs Trino 465</h3>
      <div class="tbl-wrap">
        <table class="tbl">
          <thead>
            <tr><th>Suite</th><th class="num">SQE</th><th class="num">Trino</th><th class="num">Speedup</th><th class="num">Pass</th></tr>
          </thead>
          <tbody>
            {bench.map((b) => (
              <tr>
                <td>{b.suite}</td>
                <td class="num">{b.sqe}</td>
                <td class="num">{b.trino}</td>
                <td class:list={['num', b.win ? 'cell-yes' : 'cell-no']}>{b.speedup}</td>
                <td class="num">{b.pass}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="proof-foot">
        SQE wins six of seven suites. 222/222 queries pass. SSB is the one suite SQE trails —
        lineorder’s uniform FK distribution defeats row-group pruning. Run your own with
        <code>BENCH_SCALE=1 ./scripts/benchmark-test.sh --compare-trino</code>.
      </p>

      <div class="proof-cta">
        <a class="btn btn--primary" href={DOCS}>Read the docs</a>
        <a class="btn btn--ghost-dark" href={GITHUB} rel="noopener">Star on GitHub ↗</a>
        <a class="btn btn--ghost-dark" href="/ebook">Read the book</a>
      </div>
    </div>
  </section>

  <!-- PERFORMANCE TEASER -->
  <section class="section pf-teaser-sec" id="performance">
    <div class="container">
      <SectionHeading eyebrow="Performance" title="Six of seven suites, faster than Trino." center />
      <div class="pf-teaser">
        <div class="pf-teaser__stat"><b>{perf.headline.suitesWon}</b><span>suites vs {perf.headline.vsTrino}</span></div>
        <div class="pf-teaser__stat"><b>{perf.headline.queriesPass}</b><span>queries pass, validated</span></div>
        <div class="pf-teaser__stat"><b>18.5×</b><span>top speedup</span></div>
      </div>
      <p class="pf-teaser__cta"><a href="/performance">See the performance leaps →</a></p>
    </div>
  </section>
  <style>
    .pf-teaser { display:flex; gap:18px; justify-content:center; flex-wrap:wrap; margin:8px 0 18px; }
    .pf-teaser__stat { text-align:center; min-width:130px; }
    .pf-teaser__stat b { display:block; font-size:1.9rem; color: var(--sqe-blue); font-weight:800; }
    .pf-teaser__stat span { font-size:0.84rem; color: var(--text-muted); }
    .pf-teaser__cta { text-align:center; font-weight:700; }
  </style>

  <!-- RECENTLY SHIPPED -->
  <section class="shipped">
    <div class="container shipped__inner">
      <div class="shipped__head">
        <span class="eyebrow shipped__eyebrow">Active development</span>
        <h2 class="shipped__h">Recently shipped</h2>
      </div>
      <ul class="shipped__list">
        <li><span class="shipped__date">Jun 2026</span> Read-only ops web UI, in the binary</li>
        <li><span class="shipped__date">May 2026</span> DuckDB-class embedded mode — file TVFs, <code>hf://</code>, Delta reader</li>
        <li><span class="shipped__date">May 2026</span> Column-level OpenLineage emitter</li>
      </ul>
      <a class="btn btn--ghost shipped__cta" href="/roadmap">See the roadmap →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .why-card { display: flex; flex-direction: column; }
  .why-stat { margin-bottom: 8px; }
  .why-stat .stat-num { font-size: 2.6rem; }
  .why-card h3 { font-size: 1.05rem; }
  .why-card p { font-size: 0.92rem; color: var(--text-muted); flex: 1; }
  .why-link { font-weight: 700; font-size: 0.9rem; margin-top: 10px; }

  .what { background: #fff; border-block: 1px solid var(--border); }

  .how-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .how-grid h3 { font-size: 1.1rem; margin-bottom: 14px; }
  .code {
    background: var(--midnight);
    color: #cdd9e5;
    border-radius: var(--radius-sm);
    padding: 18px 20px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.7;
    overflow-x: auto;
    border: 1px solid rgba(30, 232, 237, 0.16);
  }
  .code code { font-family: inherit; white-space: pre; }
  .how-foot { margin-top: 20px; color: var(--text-muted); }

  .proof { background: #fff; border-top: 1px solid var(--border); }
  .proof-sub { margin-top: 44px; font-size: 1.2rem; }
  .proof-foot { margin-top: 16px; font-size: 0.9rem; color: var(--text-muted); max-width: 80ch; }
  .proof-foot code, .how-foot code {
    font-family: var(--font-mono); font-size: 0.85em;
    background: var(--soft-blue); padding: 0.1em 0.4em; border-radius: 4px;
  }
  .proof-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 32px; }

  .shipped { background: var(--space-gray); color: #fff; padding-block: clamp(40px, 6vw, 64px); }
  .shipped__inner { display: grid; grid-template-columns: auto 1fr auto; gap: 32px; align-items: center; }
  .shipped__eyebrow { color: var(--turquoise); }
  .shipped__h { color: #fff; font-size: 1.5rem; margin: 6px 0 0; }
  .shipped__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .shipped__list li { color: rgba(255,255,255,0.82); font-size: 0.95rem; }
  .shipped__date { display: inline-block; min-width: 84px; font-family: var(--font-mono); font-size: 0.78rem; color: var(--turquoise); }
  .shipped__list code { font-family: var(--font-mono); background: rgba(255,255,255,0.08); color: var(--turquoise); padding: 0.05em 0.35em; border-radius: 4px; font-size: 0.88em; }
  .shipped__cta { white-space: nowrap; }

  @media (max-width: 980px) { .why-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 880px) { .shipped__inner { grid-template-columns: 1fr; gap: 18px; } }
  @media (max-width: 820px) { .how-grid { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .why-grid { grid-template-columns: 1fr; } }
</style>
