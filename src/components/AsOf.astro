---
// Small "current as of" stamp for comparison pages. One place to bump the date.
const DATE = '4 July 2026';
---
<p class="asof">Current as of {DATE} · synced from the SQE source</p>

<style>
  .asof {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0 0 26px;
  }
</style>
