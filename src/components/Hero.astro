---
// Dark hero: category claim + dual-mode terminals. Landing page only.
// Copy + terminal content come from landing.json (synced from the SQE source);
// falls back to the single embedded terminal if heroModes is absent.
import Terminal from './Terminal.astro';
import landing from '../data/landing.json';
const GITHUB = 'https://github.com/schubergphilis/sqe';
const DOCS = 'https://docs.getsqe.com';
const modes = landing.heroModes ?? [];
const lineClass = (t: string) =>
  t === 'cmd' ? 't-line' : t === 'comment' ? 't-line t-comment' : t === 'sql' ? 't-line t-sql' : 't-line t-out';
---
<section class="hero">
  <div class="container hero__inner" class:list={[modes.length && 'hero__inner--dual']}>
    <div class="hero__copy">
      <span class="hero__eyebrow">{landing.heroEyebrow}</span>
      <h1 class="hero__title" set:html={landing.heroTitle} />
      <p class="hero__lede" set:html={landing.heroLede} />
      <div class="hero__cta">
        <a class="btn btn--primary" href="/quickstart">Get started</a>
        <a class="btn btn--ghost" href={DOCS}>View docs</a>
        <a class="btn btn--ghost" href={GITHUB} rel="noopener">GitHub ↗</a>
      </div>
      <p class="hero__note" set:html={landing.heroNote} />
    </div>

    {modes.length > 0 ? (
      <div class="hero__demo hero__demo--dual">
        {modes.map((m) => (
          <div class="hero__mode">
            <span class:list={['badge-mode', `badge-mode--${m.key}`]}>{m.name}</span>
            <Terminal title={m.termTitle}>
              {m.lines.map((l) => (
                <span class={lineClass(l.t)}>
                  {l.t === 'cmd' ? <><span class="t-prompt">$</span> <span class="t-cmd">{l.s}</span></> : l.s}
                </span>
              ))}
            </Terminal>
          </div>
        ))}
        <p class="hero__same">Same query. Same result. Same identity model.</p>
      </div>
    ) : (
      <div class="hero__demo">
        <Terminal title="sqe-cli --embedded">
          <span class="t-line"><span class="t-prompt">$</span> <span class="t-cmd">sqe-cli --embedded</span></span>
          <span class="t-line t-out">SQE · DataFusion · ~/.sqe/warehouse/</span>
        </Terminal>
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    background: var(--space-gray);
    color: #fff;
    padding-block: clamp(48px, 7vw, 88px);
    background-image:
      radial-gradient(900px 400px at 78% -10%, rgba(30, 232, 237, 0.1), transparent 60%),
      radial-gradient(700px 380px at 10% 110%, rgba(30, 128, 237, 0.16), transparent 60%);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 52px;
    align-items: center;
  }
  .hero__inner--dual { grid-template-columns: minmax(0, 5fr) minmax(0, 6fr); }
  .hero__eyebrow {
    font-family: var(--font-mono);
    color: var(--turquoise);
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    font-weight: 600;
  }
  .hero__title {
    margin: 14px 0 20px;
    font-size: clamp(2.4rem, 4.6vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: #fff;
    text-wrap: balance;
  }
  .hero__lede {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.8);
    max-width: 50ch;
  }
  .hero__lede :global(strong) { color: #fff; }
  .hero__cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }
  .hero__note {
    margin-top: 22px;
    font-size: 0.86rem;
    color: rgba(255, 255, 255, 0.55);
  }
  .hero__note :global(code) {
    font-family: var(--font-mono);
    background: rgba(255, 255, 255, 0.08);
    color: var(--turquoise);
    padding: 0.15em 0.45em;
    border-radius: 5px;
    font-size: 0.92em;
  }
  .hero__demo--dual {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .hero__mode { display: flex; flex-direction: column; gap: 8px; min-width: 0; }
  .hero__mode :global(.t-sql) { color: #9fd3ff; }
  .hero__mode :global(.t-line) { font-size: 0.76rem; }
  .hero__same {
    margin: 2px 0 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--turquoise);
    letter-spacing: 0.04em;
    text-align: right;
  }

  /* ---- load choreography (CSS-only; the theme's reduced-motion blanket
     collapses every animation here to its end state) ---- */
  @keyframes sqe-rise {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes sqe-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes sqe-caret {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .hero__copy > * { animation: sqe-rise 0.55s cubic-bezier(0.2, 0.7, 0.3, 1) both; }
  .hero__copy > *:nth-child(2) { animation-delay: 0.07s; }
  .hero__copy > *:nth-child(3) { animation-delay: 0.14s; }
  .hero__copy > *:nth-child(4) { animation-delay: 0.21s; }
  .hero__copy > *:nth-child(5) { animation-delay: 0.28s; }

  /* The two terminals rise in turn, then replay their session line by line
     (delays cover up to 7 lines — the Server session is the longest). */
  .hero__mode { --td: 0.6s; animation: sqe-rise 0.6s cubic-bezier(0.2, 0.7, 0.3, 1) both 0.25s; }
  .hero__mode:nth-of-type(2) { --td: 0.85s; animation-delay: 0.4s; }
  .hero__mode :global(.term__body .t-line) { opacity: 0; animation: sqe-fade 0.3s ease forwards; }
  .hero__mode :global(.term__body .t-line:nth-child(1)) { animation-delay: var(--td); }
  .hero__mode :global(.term__body .t-line:nth-child(2)) { animation-delay: calc(var(--td) + 0.4s); }
  .hero__mode :global(.term__body .t-line:nth-child(3)) { animation-delay: calc(var(--td) + 0.8s); }
  .hero__mode :global(.term__body .t-line:nth-child(4)) { animation-delay: calc(var(--td) + 1s); }
  .hero__mode :global(.term__body .t-line:nth-child(5)) { animation-delay: calc(var(--td) + 1.35s); }
  .hero__mode :global(.term__body .t-line:nth-child(6)) { animation-delay: calc(var(--td) + 1.75s); }
  .hero__mode :global(.term__body .t-line:nth-child(7)) { animation-delay: calc(var(--td) + 2.05s); }
  .hero__mode :global(.term__body .t-line:last-child)::after {
    content: '▊';
    margin-left: 6px;
    color: var(--turquoise);
    font-style: normal;
    animation: sqe-caret 1.1s steps(1) infinite;
  }
  .hero__same { animation: sqe-fade 0.5s ease both 3.2s; }

  /* Equal-height frames when the panels sit side by side; the shorter
     session keeps its lines top-aligned. */
  .hero__mode :global(.term) { flex: 1; display: flex; flex-direction: column; }
  .hero__mode :global(.term__body) { flex: 1; }

  .hero__mode :global(.term) { transition: border-color 0.2s ease, transform 0.2s ease; }
  .hero__mode:hover :global(.term) {
    border-color: rgba(30, 232, 237, 0.42);
    transform: translateY(-2px);
  }
  @media (min-width: 1180px) {
    .hero__demo--dual { grid-template-columns: 1fr 1fr; }
    .hero__same { grid-column: 1 / -1; }
  }
  @media (max-width: 900px) {
    .hero__inner, .hero__inner--dual { grid-template-columns: 1fr; gap: 36px; }
  }
</style>
