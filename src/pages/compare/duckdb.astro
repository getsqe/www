---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CompareTable from '../../components/CompareTable.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import AsOf from '../../components/AsOf.astro';

// Curated comparison (derived from the synced duckdb-comparision source doc).
// The raw source is an internal audit/roadmap; this page keeps the
// differentiators, the DuckDB-inspired features SQE shipped, and the honest
// remaining gaps — without the "done" changelog rows. See PUBLISH-CHECKLIST.

// 1. What SQE has that DuckDB doesn't.
const aheadHead = ['', 'SQE', 'DuckDB'];
const aheadRows = [
  { label: 'Execution model', cells: [{ t: 'embedded <em>and</em> distributed', tone: 'emph' }, { t: 'single process' }] },
  { label: 'Per-query OIDC bearer passthrough', cells: [{ t: 'yes', tone: 'yes' }, { t: 'no', tone: 'no' }] },
  { label: 'OPA / Cedar policy (row filters, masks)', cells: [{ t: 'yes', tone: 'yes' }, { t: 'no', tone: 'no' }] },
  { label: 'Multi-catalog in one engine', cells: [{ t: 'Polaris · Nessie · Glue · HMS · S3 Tables', tone: 'emph' }, { t: 'extension-by-extension' }] },
  { label: 'Iceberg V3 read + write', cells: [{ t: 'native', tone: 'emph' }, { t: 'extension, read-only' }] },
  { label: 'Arrow Flight SQL wire protocol', cells: [{ t: 'yes', tone: 'yes' }, { t: 'extension' }] },
];

// 2. DuckDB-inspired capabilities SQE shipped (the "done" items, as a resume).
const inspired = [
  { title: 'Embedded single binary', body: '<code>sqe-cli --embedded</code> — a DuckDB-class single-process engine with a persistent SQLite-backed warehouse at <code>~/.sqe/warehouse/</code>.' },
  { title: 'File-format table functions', body: '<code>read_parquet</code>, <code>read_csv</code> (full DuckDB-parity options), <code>read_json</code> / <code>read_json_auto</code>, <code>read_avro</code>, and <code>read_delta</code> with Delta Lake time-travel.' },
  { title: 'Query a file directly', body: "<code>SELECT * FROM 'file.parquet'</code> auto-detects parquet, csv, json, and avro on local, S3, HTTPS, and hf:// paths." },
  { title: 'COPY … TO', body: 'Native <code>COPY &lt;source&gt; TO \'file\' (FORMAT csv|json|parquet)</code> export, plus CTAS across formats.' },
  { title: 'Network-transparent access', body: 'An <code>httpfs</code>-equivalent for HTTP/HTTPS/S3, the AWS provider chain, Azure ADLS Gen2, GCS, and Cloudflare R2.' },
  { title: 'HuggingFace hf:// URLs', body: '<code>hf://datasets/owner/name/path</code> with <code>?revision=</code> / <code>@rev</code> pinning and the <code>@~parquet</code> auto-view.' },
  { title: 'CSV ergonomics', body: 'Extension-based delimiter + codec auto-detect (<code>.tsv</code>, <code>.gz</code>, <code>.zst</code>…) and DuckDB-friendly aliases (<code>sep</code>, <code>delim</code>, <code>header</code>).' },
  { title: 'SQL niceties', body: '<code>DESCRIBE</code>, <code>SUMMARIZE</code>, <code>SELECT * EXCLUDE (…)</code>, and <code>SELECT * REPLACE (… AS col)</code>.' },
];

// 3. What DuckDB still has that SQE doesn't (genuine gaps only — no "done" rows).
const gaps = [
  { feature: 'FROM-first syntax (<code>FROM t SELECT …</code>)', reason: 'DataFusion parser does not support it' },
  { feature: 'Struct / list / map literal sugar', reason: 'Partial — nested types work, the literal syntax is less ergonomic' },
  { feature: 'List comprehensions, lambdas', reason: 'DataFusion does not support them' },
  { feature: '<code>PIVOT</code> / <code>UNPIVOT</code>', reason: 'DataFusion parser does not support it' },
  { feature: '<code>QUALIFY</code>', reason: 'DataFusion parser does not support it' },
  { feature: '<code>ASOF JOIN</code>', reason: 'Open upstream issue, not yet landed' },
  { feature: '<code>postgres</code> / <code>mysql</code> / <code>sqlite</code> connectors', reason: 'Positioning: SQE is Iceberg-first' },
  { feature: '<code>spatial</code>, <code>vss</code>, <code>fts</code>, <code>excel</code>', reason: 'Niche — use a purpose-built engine' },
  { feature: 'HuggingFace glob (<code>**/*.parquet</code>)', reason: 'In progress — tree-API cache landed, object-store wiring next' },
];
---
<BaseLayout
  title="SQE vs DuckDB — embedded engine comparison | getsqe.com"
  description="SQE matches DuckDB on the embedded side — file-format TVFs, hf:// URLs, a Delta reader, httpfs-equivalent access — then scales the same binary to a multi-tenant, policy-enforced cluster."
>
  <section class="section">
    <div class="container doc">
      <SectionHeading eyebrow="Comparison" title="SQE vs DuckDB" />
      <AsOf />
      <p class="lead">
        The goal isn’t to <em>be</em> DuckDB. SQE is the Iceberg-first analytical engine that runs
        both as an embedded single binary <strong>and</strong> as a distributed cluster with OIDC
        pass-through and policy enforcement. Where SQE matches DuckDB on the embedded side, the
        same binary scales to a multi-tenant cluster.
      </p>
      <p class="crumb"><a href="/compare/iceberg">Iceberg matrix</a> · <a href="/compare/trino">vs Trino</a> · <a href="/compare/features">SQL features</a></p>
    </div>

    <div class="container block">
      <h2 class="block__h section-marker">What SQE has that DuckDB doesn’t</h2>
      <CompareTable head={aheadHead} rows={aheadRows} />
    </div>

    <div class="container block">
      <h2 class="block__h section-marker">DuckDB-inspired, now in SQE</h2>
      <p class="block__sub">The embedded-mode capabilities SQE grew while chasing DuckDB’s
        developer ergonomics — all on the same binary that runs the cluster.</p>
      <FeatureGrid items={inspired} columns={4} />
    </div>

    <div class="container block">
      <h2 class="block__h section-marker">What DuckDB still has that SQE doesn’t</h2>
      <div class="tbl-wrap">
        <table class="tbl">
          <thead><tr><th>Capability</th><th>Why not (yet)</th></tr></thead>
          <tbody>
            {gaps.map((g) => (
              <tr>
                <td set:html={g.feature} />
                <td class="gap-reason">{g.reason}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="container block">
      <div class="smoke">
        <span class="eyebrow">Smoke test</span>
        <p>Loading DuckDB’s own <code>train_services.parquet</code> over HTTPS, same machine,
          same network:</p>
        <div class="smoke__row">
          <div class="smoke__stat"><span class="stat-num">1.618s</span><span class="smoke__who">SQE embedded</span></div>
          <div class="smoke__stat"><span class="stat-num smoke__muted">1.815s</span><span class="smoke__who">DuckDB v1.4.4</span></div>
        </div>
        <p class="smoke__note">Not a benchmark claim — a single-query smoke test that says embedded
          mode is at least as fast as DuckDB on a basic file load.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .doc { max-width: 900px; }
  .lead { font-size: 1.12rem; color: var(--text); max-width: 70ch; }
  .crumb { font-size: 0.9rem; color: var(--text-muted); margin-top: 10px; }
  .block { max-width: 1000px; margin-top: 52px; }
  .block__h { font-size: 1.45rem; margin-bottom: 18px; }
  .block__sub { color: var(--text-muted); max-width: 70ch; margin-top: -6px; margin-bottom: 22px; }
  .gap-reason { color: var(--text-muted); }
  table.tbl :global(code) {
    font-family: var(--font-mono); font-size: 0.85em;
    background: var(--soft-blue); padding: 0.1em 0.35em; border-radius: 4px;
  }
  .smoke {
    background: var(--space-gray); color: #fff; border-radius: var(--radius);
    padding: 30px 32px;
  }
  .smoke .eyebrow { color: var(--turquoise); }
  .smoke p { color: rgba(255, 255, 255, 0.78); }
  .smoke code { font-family: var(--font-mono); background: rgba(255,255,255,0.08); color: var(--turquoise); padding: 0.1em 0.4em; border-radius: 4px; font-size: 0.9em; }
  .smoke__row { display: flex; gap: 48px; margin: 18px 0; }
  .smoke__stat { display: flex; flex-direction: column; }
  .smoke__stat .stat-num { font-size: 2.4rem; color: var(--turquoise); }
  .smoke__muted { color: rgba(255,255,255,0.55) !important; }
  .smoke__who { font-family: var(--font-mono); font-size: 0.8rem; color: rgba(255,255,255,0.6); margin-top: 2px; }
  .smoke__note { font-size: 0.85rem; color: rgba(255,255,255,0.55) !important; margin-top: 6px; }
</style>
