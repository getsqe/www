---
// Renders the filtered Iceberg matrix: capability rows with V2/V3 columns,
// each cell colored by support level. Headline score on top.
interface Cell {
  key: string;
  feature: string;
  version: string;
  level: 'full' | 'partial' | 'none';
}
interface MatrixData {
  score: { raw: number; max: number; percent: number };
  docUrl: string;
  cells: Cell[];
}
interface Props {
  data: MatrixData;
}
const { data } = Astro.props;

// Group cells by feature, slot into V2 / V3.
const byFeature = new Map<string, { feature: string; v2?: string; v3?: string }>();
for (const c of data.cells) {
  const row = byFeature.get(c.feature) ?? { feature: c.feature };
  if (c.version === 'V2') row.v2 = c.level;
  else if (c.version === 'V3') row.v3 = c.level;
  byFeature.set(c.feature, row);
}
const rows = [...byFeature.values()].sort((a, b) => a.feature.localeCompare(b.feature));

const counts = data.cells.reduce(
  (acc, c) => ((acc[c.level] = (acc[c.level] ?? 0) + 1), acc),
  {} as Record<string, number>,
);

const LEVEL_LABEL: Record<string, string> = { full: 'Full', partial: 'Partial', none: 'None' };
function cls(level?: string) {
  if (!level) return 'mx-cell mx-na';
  return `mx-cell mx-${level}`;
}
---
<div class="mx">
  <div class="mx__score">
    <div class="mx__big">
      <span class="stat-num">{data.score.raw}</span><span class="mx__sep">/</span><span class="mx__max">{data.score.max}</span>
    </div>
    <div class="mx__pct"><span class="stat-num">{data.score.percent}%</span> coverage</div>
    <p class="mx__caption">
      Self-reported against the public <a href="https://icebergmatrix.org" rel="noopener">Iceberg matrix</a> rubric.
      Top-five overall; only non-Spark engine in the top five.
    </p>
    <div class="mx__legend">
      <span><i class="dot mx-full"></i> Full ({counts.full ?? 0})</span>
      <span><i class="dot mx-partial"></i> Partial ({counts.partial ?? 0})</span>
      <span><i class="dot mx-none"></i> None ({counts.none ?? 0})</span>
    </div>
  </div>

  <div class="tbl-wrap">
    <table class="mx__tbl">
      <thead>
        <tr><th>Capability</th><th>V2</th><th>V3</th></tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <td class="mx__feat">{r.feature}</td>
            <td class={cls(r.v2)}>{r.v2 ? LEVEL_LABEL[r.v2] : '—'}</td>
            <td class={cls(r.v3)}>{r.v3 ? LEVEL_LABEL[r.v3] : '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .mx { display: grid; grid-template-columns: 320px 1fr; gap: 32px; align-items: start; }
  .mx__score {
    position: sticky;
    top: 24px;
    background: var(--space-gray);
    color: #fff;
    border-radius: var(--radius);
    padding: 26px;
  }
  .mx__big { font-size: 2.8rem; line-height: 1; display: flex; align-items: baseline; }
  .mx__big .stat-num { color: var(--turquoise); font-size: 3rem; }
  .mx__sep { color: rgba(255, 255, 255, 0.4); margin: 0 4px; font-weight: 800; }
  .mx__max { color: rgba(255, 255, 255, 0.55); font-family: var(--font-mono); font-weight: 800; }
  .mx__pct { margin-top: 8px; color: rgba(255, 255, 255, 0.75); }
  .mx__pct .stat-num { color: #fff; font-size: 1.1rem; }
  .mx__caption { margin-top: 14px; font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); }
  .mx__legend { display: flex; flex-direction: column; gap: 6px; margin-top: 16px; font-size: 0.84rem; font-family: var(--font-mono); }
  .dot { display: inline-block; width: 10px; height: 10px; border-radius: 3px; margin-right: 6px; vertical-align: middle; }

  .mx__tbl { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
  .mx__tbl th { text-align: left; padding: 10px 14px; background: var(--soft-blue); font-weight: 800; }
  .mx__tbl th:not(:first-child), .mx__tbl td:not(:first-child) { text-align: center; width: 120px; }
  .mx__tbl td { padding: 9px 14px; border-bottom: 1px solid var(--border); }
  .mx__feat { font-weight: 600; }
  .mx-cell { font-family: var(--font-mono); font-size: 0.82rem; font-weight: 700; }
  .mx-full, td.mx-full { color: var(--green); }
  .mx-partial, td.mx-partial { color: #b7791f; }
  .mx-none, td.mx-none { color: var(--red); }
  .mx-na { color: var(--gray-medium); }
  .dot.mx-full { background: var(--green); }
  .dot.mx-partial { background: var(--yellow); }
  .dot.mx-none { background: var(--red); }
  @media (max-width: 820px) { .mx { grid-template-columns: 1fr; } .mx__score { position: static; } }
</style>
