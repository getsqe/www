---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

// Authored prose synced from docs/site/web/about.md (single content home).
// The markdown carries its own H1 + section headings, so this page renders it
// directly rather than re-stating the copy in bespoke hero/credit markup.
const entry = await getEntry('web', 'about');
if (!entry) throw new Error('web/about.md not found — run `npm run sync`');
const { Content } = await render(entry);
const { title, description } = entry.data as { title?: string; description?: string };
---
<BaseLayout
  title={title ?? 'About SQE — Sovereign Query Engine'}
  description={description ?? "SQE started as a fork of Trino with end-to-end authentication instead of service accounts. Built at Schuberg Philis by Jacob Verhoeks & Rafael Herrero, it's the open-source engine at the heart of a sovereign data platform."}
  darkHeader
>
  <section class="section">
    <div class="container about-body">
      <article class="prose"><Content /></article>
    </div>
  </section>
</BaseLayout>

<style>
  .about-body { max-width: 760px; }
</style>
