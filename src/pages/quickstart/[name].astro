---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { allQuickstarts, docsUrl, repoUrl } from '../../data/quickstarts';

export const getStaticPaths = (async () => {
  const entries = await getCollection('quickstartOverview');
  return entries.map((entry) => {
    const meta = allQuickstarts.find((q) => q.name === entry.id) ?? { name: entry.id, title: entry.id, blurb: '' };
    return { params: { name: entry.id }, props: { entry, meta } };
  });
}) satisfies GetStaticPaths;

const { entry, meta } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout title={`${meta.title} — SQE quickstart | getsqe.com`} description={meta.blurb} darkHeader>
  <section class="qd-hero"><div class="container">
    <p class="qd-crumb"><a href="/quickstart">← All quickstarts</a></p>
    <span class="qd-eyebrow">Quickstart{meta.experimental ? ' · experimental' : ''}</span>
  </div></section>
  <section class="section"><div class="container qd-body">
    <article class="prose qd-overview"><Content /></article>
    <div class="qd-cta">
      <a class="qd-btn qd-btn--primary" href={docsUrl(meta.name)}>Full guide →</a>
      <a class="qd-btn" href={repoUrl(meta.name)} rel="noopener">Code ↗</a>
      <a class="qd-btn qd-btn--ghost" href="/quickstart">All quickstarts</a>
    </div>
  </div></section>
</BaseLayout>
<style>
  .qd-hero { background: var(--space-gray); color:#fff; padding-block: clamp(32px,5vw,56px); }
  .qd-crumb { margin:0 0 12px; font-size:0.9rem; } .qd-crumb a { color: var(--turquoise); }
  .qd-eyebrow { font-family: var(--font-mono); color: var(--turquoise); font-size:0.82rem; letter-spacing:0.1em; font-weight:600; }
  .qd-body { max-width: 820px; }
  .qd-overview :global(h1) { font-size: clamp(1.8rem,3.5vw,2.4rem); margin:0 0 18px; }
  .qd-overview :global(h2) { font-size:1.3rem; margin:32px 0 10px; padding-top:14px; border-top:1px solid var(--border); }
  .qd-overview :global(h3) { font-size:1rem; font-family:var(--font-mono); color:var(--sqe-blue); margin:18px 0 6px; }
  .qd-overview :global(pre) { background: var(--midnight); color:#e6edf3; border:1px solid rgba(30,232,237,0.18); border-radius:10px; padding:16px; overflow-x:auto; font-size:0.84rem; }
  .qd-overview :global(table) { width:100%; border-collapse:collapse; font-size:0.9rem; }
  .qd-overview :global(th), .qd-overview :global(td) { border:1px solid var(--border); padding:6px 10px; text-align:left; }
  .qd-cta { display:flex; gap:14px; flex-wrap:wrap; align-items:center; margin-top:36px; padding-top:18px; border-top:1px solid var(--border); }
  .qd-btn { font-weight:700; font-size:0.95rem; padding:9px 16px; border-radius:8px; border:1px solid var(--border); }
  .qd-btn--primary { background: var(--sqe-blue); color:#fff; border-color: var(--sqe-blue); }
  .qd-btn--ghost { color: var(--text-muted); }
</style>
