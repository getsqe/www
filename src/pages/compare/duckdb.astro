---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CompareTable from '../../components/CompareTable.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import AsOf from '../../components/AsOf.astro';
import Terminal from '../../components/Terminal.astro';
import compare from '../../data/compare-duckdb.json';

// Authored comparison copy synced from docs/site/web/compare-duckdb.json.
// Keeps the differentiators, the DuckDB-inspired features SQE shipped, and the
// honest remaining gaps — without the "done" changelog rows.
const { aheadHead, aheadRows, inspired, gaps } = compare;
---
<BaseLayout
  title="SQE vs DuckDB — embedded engine comparison | getsqe.com"
  description="SQE matches DuckDB on the embedded side — file-format TVFs, hf:// URLs, a Delta reader, httpfs-equivalent access — then scales the same binary to a multi-tenant, policy-enforced cluster."
  darkHeader
>
  <PageHero
    eyebrow="Comparison"
    title="SQE vs DuckDB"
    lede="The goal isn’t to <em>be</em> DuckDB. SQE is the Iceberg-first analytical engine that runs both as an embedded single binary <strong>and</strong> as a distributed cluster with OIDC pass-through and policy enforcement. Where SQE matches DuckDB on the embedded side, the same binary scales to a multi-tenant cluster."
  />
  <section class="section">
    <div class="container doc">
      <AsOf />
      <p class="crumb"><a href="/compare/iceberg">Iceberg matrix</a> · <a href="/compare/trino">vs Trino</a> · <a href="/compare/features">SQL features</a></p>
    </div>

    <div class="container block">
      <h2 class="block__h section-marker">What SQE has that DuckDB doesn’t</h2>
      <CompareTable head={aheadHead} rows={aheadRows} />
    </div>

    <div class="container block">
      <h2 class="block__h section-marker">DuckDB-inspired, now in SQE</h2>
      <p class="block__sub">The embedded-mode capabilities SQE grew while chasing DuckDB’s
        developer ergonomics — all on the same binary that runs the cluster.</p>
      <FeatureGrid items={inspired} columns={4} />
    </div>

    <div class="container block">
      <h2 class="block__h section-marker">See it — DuckDB-style, in SQE</h2>
      <p class="block__sub">The same file-first ergonomics, in an embedded <code>sqe-cli</code> session.
        No cluster, no catalog setup.</p>
      <Terminal title="sqe-cli --embedded">
        <span class="t-line t-comment"># Query a Parquet file directly — no table, no setup</span>
        <span class="t-line"><span class="t-prompt">sqe&gt;</span> <span class="t-kw">SELECT</span> <span class="t-fn">count</span>(*) <span class="t-kw">FROM</span> <span class="t-str">'data/events.parquet'</span>;</span>
        <span class="t-line t-out">┌──────────┐
│ count(*) │
├──────────┤
│ 1048576  │
└──────────┘</span>
        <span class="t-line"> </span>
        <span class="t-line t-comment"># read_csv with DuckDB-parity options + gzip auto-detect</span>
        <span class="t-line"><span class="t-prompt">sqe&gt;</span> <span class="t-kw">SELECT</span> * <span class="t-kw">FROM</span> <span class="t-fn">read_csv</span>(<span class="t-str">'s3://bucket/orders.tsv.gz'</span>, header =&gt; <span class="t-kw">true</span>) <span class="t-kw">LIMIT</span> 3;</span>
        <span class="t-line"> </span>
        <span class="t-line t-comment"># A HuggingFace dataset, straight from the hf:// URL</span>
        <span class="t-line"><span class="t-prompt">sqe&gt;</span> <span class="t-kw">SELECT</span> * <span class="t-kw">FROM</span> <span class="t-str">'hf://datasets/squad/plain_text/train.parquet'</span> <span class="t-kw">LIMIT</span> 5;</span>
        <span class="t-line"> </span>
        <span class="t-line t-comment"># Delta Lake with time travel</span>
        <span class="t-line"><span class="t-prompt">sqe&gt;</span> <span class="t-kw">SELECT</span> * <span class="t-kw">FROM</span> <span class="t-fn">read_delta</span>(<span class="t-str">'/data/delta/sales'</span>, version =&gt; <span class="t-str">'5'</span>);</span>
        <span class="t-line"> </span>
        <span class="t-line t-comment"># Export results back out</span>
        <span class="t-line"><span class="t-prompt">sqe&gt;</span> <span class="t-kw">COPY</span> (<span class="t-kw">SELECT</span> * <span class="t-kw">FROM</span> orders <span class="t-kw">WHERE</span> region=<span class="t-str">'EU'</span>) <span class="t-kw">TO</span> <span class="t-str">'eu.parquet'</span>;</span>
      </Terminal>
    </div>

    <div class="container block">
      <h2 class="block__h section-marker">What DuckDB still has that SQE doesn’t</h2>
      <div class="tbl-wrap">
        <table class="tbl">
          <thead><tr><th>Capability</th><th>Why not (yet)</th></tr></thead>
          <tbody>
            {gaps.map((g) => (
              <tr>
                <td set:html={g.feature} />
                <td class="gap-reason">{g.reason}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="container block">
      <div class="smoke">
        <span class="eyebrow">Smoke test</span>
        <p>Loading DuckDB’s own <code>train_services.parquet</code> over HTTPS, same machine,
          same network:</p>
        <div class="smoke__row">
          <div class="smoke__stat"><span class="stat-num">1.618s</span><span class="smoke__who">SQE embedded</span></div>
          <div class="smoke__stat"><span class="stat-num smoke__muted">1.815s</span><span class="smoke__who">DuckDB v1.4.4</span></div>
        </div>
        <p class="smoke__note">Not a benchmark claim — a single-query smoke test that says embedded
          mode is at least as fast as DuckDB on a basic file load.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .doc { max-width: 900px; }
  .crumb { font-size: 0.9rem; color: var(--text-muted); margin-top: 10px; }
  .block { max-width: 1000px; margin-top: 52px; }
  .block__h { font-size: 1.45rem; margin-bottom: 18px; }
  .block__sub { color: var(--text-muted); max-width: 70ch; margin-top: -6px; margin-bottom: 22px; }
  .gap-reason { color: var(--text-muted); }
  table.tbl :global(code) {
    font-family: var(--font-mono); font-size: 0.85em;
    background: var(--soft-blue); padding: 0.1em 0.35em; border-radius: 4px;
  }
  .smoke {
    background: var(--space-gray); color: #fff; border-radius: var(--radius);
    padding: 30px 32px;
  }
  .smoke .eyebrow { color: var(--turquoise); }
  .smoke p { color: rgba(255, 255, 255, 0.78); }
  .smoke code { font-family: var(--font-mono); background: rgba(255,255,255,0.08); color: var(--turquoise); padding: 0.1em 0.4em; border-radius: 4px; font-size: 0.9em; }
  .smoke__row { display: flex; gap: 48px; margin: 18px 0; }
  .smoke__stat { display: flex; flex-direction: column; }
  .smoke__stat .stat-num { font-size: 2.4rem; color: var(--turquoise); }
  .smoke__muted { color: rgba(255,255,255,0.55) !important; }
  .smoke__who { font-family: var(--font-mono); font-size: 0.8rem; color: rgba(255,255,255,0.6); margin-top: 2px; }
  .smoke__note { font-size: 0.85rem; color: rgba(255,255,255,0.55) !important; margin-top: 6px; }
</style>
