---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import AsOf from '../../components/AsOf.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('compare', 'trino');
if (!entry) throw new Error('compare/trino content missing — run npm run sync');
const { Content } = await render(entry);
---
<BaseLayout
  title="SQE vs Trino — SQL & feature compatibility | getsqe.com"
  description="SQE targets ~96% Trino SQL compatibility for Iceberg-only workloads, speaks the Trino HTTP wire protocol, and runs as the authenticated user instead of a service account."
  darkHeader
>
  <PageHero
    eyebrow="Comparison"
    title="SQE vs Trino"
    lede="SQE is a drop-in replacement for Trino in <strong>Iceberg-only</strong> environments — roughly <strong>96% SQL compatibility</strong>, the <strong>Trino HTTP</strong> wire protocol so existing clients and dbt models connect unchanged, and per-query identity instead of a shared service account. The matrix below maps every Trino function and feature to its SQE equivalent."
  />
  <section class="section">
    <div class="container doc">
      <AsOf />
      <p class="legend">
        <span class="legend__k"><b class="ok">✅</b> equivalent</span>
        <span class="legend__k"><b class="warn">⚠️</b> partial / different</span>
        <span class="legend__k"><b class="no">❌</b> missing</span>
        <span class="legend__k"><b class="sqe">🔧</b> SQE-specific</span>
      </p>
      <p class="crumb"><a href="/compare/iceberg">Iceberg matrix</a> · <a href="/compare/duckdb">vs DuckDB</a> · <a href="/compare/features">SQL features</a></p>
      <article class="prose"><Content /></article>
    </div>
  </section>
</BaseLayout>

<style>
  .doc { max-width: 900px; }
  .legend { display: flex; gap: 18px; flex-wrap: wrap; font-size: 0.86rem; color: var(--text-muted); margin: 6px 0 6px; }
  .legend b { font-style: normal; }
  .crumb { font-size: 0.9rem; color: var(--text-muted); margin: 8px 0 6px; }
</style>
