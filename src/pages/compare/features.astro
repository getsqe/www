---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import AsOf from '../../components/AsOf.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('compare', 'features');
if (!entry) throw new Error('compare/features content missing — run npm run sync');
const { Content } = await render(entry);
---
<BaseLayout
  title="SQL feature comparison — SQE vs Trino, Spark, DuckDB | getsqe.com"
  description="SQE's SQL surface across windows, aggregates, DML, Iceberg operations, and file-format table functions, compared with Trino, Spark SQL, and DuckDB."
  darkHeader
>
  <PageHero
    eyebrow="Comparison"
    title="SQL feature comparison"
    lede="SQE runs on <strong>Apache DataFusion</strong>, so the standard SQL surface — windows, aggregates, joins, CTEs, set operations — comes for free. SQE adds multi-catalog integration, pluggable auth, distributed execution, Iceberg DML, and a single-binary embedded mode. Here it is side by side with Trino, Spark SQL, and DuckDB."
  />
  <section class="section">
    <div class="container doc">
      <AsOf />
      <p class="crumb"><a href="/compare/iceberg">Iceberg matrix</a> · <a href="/compare/trino">vs Trino</a> · <a href="/compare/duckdb">vs DuckDB</a></p>
      <article class="prose"><Content /></article>
    </div>
  </section>
</BaseLayout>

<style>
  .doc { max-width: 900px; }
  /* PageHero already renders the page title; the synced markdown leads with
     its own H1 — hide it so exactly one heading is exposed. */
  .doc .prose :global(h1) { display: none; }
  .crumb { font-size: 0.9rem; color: var(--text-muted); margin: 8px 0 6px; }
</style>
