---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getEntry, render } from 'astro:content';

// Authored copy is synced from docs/site/web/about.md (single content home in
// the SQE repo). The hero headline/lede come from that file's frontmatter; the
// narrative blocks and the credit line are its markdown body. Fields are
// optional with fallbacks so this page builds even before the richer frontmatter
// has synced.
const entry = await getEntry('web', 'about');
if (!entry) throw new Error('web/about.md not found — run `npm run sync`');
const { Content } = await render(entry);
const data = entry.data as {
  title?: string;
  description?: string;
  eyebrow?: string;
  heroTitle?: string;
  heroLede?: string;
};
const eyebrow = data.eyebrow ?? 'About SQE';
const heroTitle = data.heroTitle ?? 'Make the query the identity.';
const heroLede = data.heroLede;
---
<BaseLayout
  title={data.title ?? 'About SQE — Sovereign Query Engine'}
  description={data.description ?? "SQE started as a fork of Trino with end-to-end authentication instead of service accounts. Built at Schuberg Philis by Jacob Verhoeks & Rafael Herrero, it's the open-source engine at the heart of a sovereign data platform."}
  darkHeader
>
  <PageHero eyebrow={eyebrow} title={heroTitle} lede={heroLede} />

  <section class="section">
    <div class="container about-body">
      <article class="prose"><Content /></article>
    </div>
  </section>
</BaseLayout>

<style>
  .about-body { max-width: 760px; }
  .about-body .prose h2 { font-size: 1.6rem; margin: 36px 0 14px; }
  .about-body .prose p { font-size: 1.08rem; color: var(--text); }
</style>
