---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import matrix from '../data/iceberg-matrix.json';
import roadmapData from '../data/roadmap.json';

const GITHUB = 'https://github.com/schubergphilis/sqe';

// The authored copy (docs/site/web/roadmap.json) carries literal
// ${matrix.score.*} placeholders so the numbers stay data-driven. JSON strings
// are not template literals, so interpolate them against the synced matrix here.
const fill = (s: string) =>
  s.replace(/\$\{matrix\.score\.(\w+)\}/g, (_m, k) => String((matrix.score as Record<string, unknown>)[k]));

// Current-state snapshot (curated from the SQE roadmap / status log; sanitized).
const state = roadmapData.state.map((s) => ({ num: fill(s.num), label: fill(s.label) }));

// Recent milestones, newest first. Curated + sanitized from the status log:
// no account ids, regions, branch names, MR numbers, or internal paths.
const milestones = roadmapData.milestones.map((m) => ({ ...m, body: fill(m.body) }));

// Open roadmap — verified against the current state: items already shipped
// (OPA/Cedar policy, Azure/GCS stores, map-producing UDAFs) are intentionally
// NOT listed here, since they're done.
const roadmap = roadmapData.roadmap;
const roadmapGroups = [
  { key: 'In progress', tone: 'progress', items: roadmap.progress },
  { key: 'Planned', tone: 'planned', items: roadmap.planned },
  { key: 'Blocked upstream', tone: 'blocked', items: roadmap.blocked },
];
---
<BaseLayout
  title="Roadmap — SQE current state & what’s next | getsqe.com"
  description="Where SQE is and where it’s going: 88.4% on the Iceberg matrix, 6/7 benchmark suites won, a read-only ops web UI — plus the verified open roadmap of what’s in progress, planned, and blocked upstream."
  darkHeader
>
  <section class="log-hero">
    <div class="container">
      <span class="log-eyebrow">Roadmap</span>
      <h1>Where SQE is, and what’s next.</h1>
      <p class="log-lede">
        SQE is in active development. This is the current state, the milestones that got it here,
        and the verified open roadmap — the full commit history lives on
        <a href={GITHUB} rel="noopener">GitHub</a>.
      </p>
      <div class="log-state">
        {state.map((s) => (
          <div class="log-state__card">
            <span class="stat-num">{s.num}</span>
            <span class="log-state__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container log-body">
      <SectionHeading eyebrow="Milestones" title="Recently shipped" />
      <ol class="timeline">
        {milestones.map((m) => (
          <li class="timeline__item">
            <div class="timeline__rail"><span class="timeline__dot"></span></div>
            <div class="timeline__content">
              <span class="timeline__date">{m.date}</span>
              <h3>{m.title}</h3>
              <p set:html={m.body} />
            </div>
          </li>
        ))}
      </ol>
      <p class="log-foot">
        Design rationale for many of these lives in the book,
        <a href="/ebook">Sovereign by Design</a>, and in the engineering blog in the
        <a href={GITHUB} rel="noopener">source repository</a>.
      </p>
    </div>
  </section>

  <section class="section section--tight roadmap">
    <div class="container log-body">
      <SectionHeading eyebrow="Roadmap" title="What’s open" yellow />
      <p class="roadmap__intro">
        Verified against the current state — features that have shipped are <em>not</em> listed
        here. Grouped by where each item stands today.
      </p>
      <div class="roadmap__grid">
        {roadmapGroups.map((g) => (
          <div class={`rmcol rmcol--${g.tone}`}>
            <h3 class="rmcol__h">{g.key}<span class="rmcol__n">{g.items.length}</span></h3>
            <ul class="rmcol__list">
              {g.items.map((it) => (
                <li>
                  <span class="rmcol__t" set:html={it.t} />
                  <span class="rmcol__d">{it.d}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .log-hero {
    background: var(--space-gray); color: #fff;
    padding-block: clamp(48px, 7vw, 88px);
    background-image: radial-gradient(800px 360px at 82% -10%, rgba(30, 232, 237, 0.1), transparent 60%);
  }
  .log-eyebrow { font-family: var(--font-mono); color: var(--turquoise); font-size: 0.82rem; letter-spacing: 0.1em; font-weight: 600; }
  .log-hero h1 { color: #fff; margin: 12px 0 16px; }
  .log-lede { color: rgba(255,255,255,0.82); max-width: 56ch; font-size: 1.1rem; }
  .log-state { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 34px; }
  .log-state__card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 18px; display: flex; flex-direction: column; gap: 6px; }
  .log-state__card .stat-num { color: var(--turquoise); font-size: 1.9rem; }
  .log-state__label { font-size: 0.82rem; color: rgba(255,255,255,0.7); }

  .log-body { max-width: 800px; }
  .timeline { list-style: none; padding: 0; margin: 0; }
  .timeline__item { display: grid; grid-template-columns: 28px 1fr; gap: 18px; }
  .timeline__rail { display: flex; flex-direction: column; align-items: center; }
  .timeline__dot { width: 13px; height: 13px; border-radius: 50%; background: var(--sqe-blue); margin-top: 6px; box-shadow: 0 0 0 4px var(--soft-blue); }
  .timeline__item:not(:last-child) .timeline__rail::after { content: ''; flex: 1; width: 2px; background: var(--border); margin-top: 4px; }
  .timeline__content { padding-bottom: 30px; }
  .timeline__date { font-family: var(--font-mono); font-size: 0.78rem; color: var(--sqe-blue); font-weight: 600; }
  .timeline__content h3 { font-size: 1.2rem; margin: 4px 0 8px; }
  .timeline__content p { color: var(--text-muted); margin: 0; }
  .timeline__content :global(code) { font-family: var(--font-mono); font-size: 0.85em; background: var(--soft-blue); padding: 0.1em 0.35em; border-radius: 4px; color: var(--midnight); }
  .log-foot { margin-top: 18px; color: var(--text-muted); }

  @media (max-width: 820px) { .log-state { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .log-state { grid-template-columns: 1fr; } }

  .roadmap { background: #fff; border-top: 1px solid var(--border); }
  .roadmap__intro { color: var(--text-muted); max-width: 70ch; margin: -6px 0 28px; }
  .roadmap__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .rmcol { border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; border-top-width: 3px; }
  .rmcol--progress { border-top-color: var(--green); }
  .rmcol--planned { border-top-color: var(--sqe-blue); }
  .rmcol--blocked { border-top-color: var(--gray-medium); }
  .rmcol__h { display: flex; align-items: center; justify-content: space-between; font-size: 1.05rem; margin: 0 0 14px; }
  .rmcol__n { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-muted); font-weight: 700; }
  .rmcol__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px; }
  .rmcol__list li { display: flex; flex-direction: column; gap: 3px; }
  .rmcol__t { font-weight: 700; font-size: 0.92rem; }
  .rmcol__t :global(code) { font-family: var(--font-mono); font-size: 0.85em; background: var(--soft-blue); padding: 0.1em 0.35em; border-radius: 4px; }
  .rmcol__d { font-size: 0.86rem; color: var(--text-muted); }
  @media (max-width: 820px) { .roadmap__grid { grid-template-columns: 1fr; } }
</style>
